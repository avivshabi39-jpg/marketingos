{
  "buildCommand": "npx prisma generate --schema=packages/db/prisma/schema.prisma && cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {"path": "/api/cron/weekly-agent-report", "schedule": "0 8 * * 1"},
    {"path": "/api/cron/email-sequences", "schedule": "0 9 * * *"},
    {"path": "/api/cron/overnight-optimizer", "schedule": "0 2 * * *"}
  ]
}
