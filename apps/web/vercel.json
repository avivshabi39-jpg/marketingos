{
  "buildCommand": "npx prisma generate --schema=../../packages/db/prisma/schema.prisma && next build",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {"path": "/api/cron/health-check", "schedule": "*/30 * * * *"},
    {"path": "/api/cron/backup", "schedule": "0 2 * * 0"},
    {"path": "/api/cron/weekly-agent-report", "schedule": "0 8 * * 1"},
    {"path": "/api/cron/email-sequences", "schedule": "0 9 * * *"},
    {"path": "/api/cron/overnight-optimizer", "schedule": "0 2 * * *"},
    {"path": "/api/cron/auto-cleanup", "schedule": "0 3 1 * *"},
    {"path": "/api/cron/whatsapp-drip", "schedule": "0 10 * * *"},
    {"path": "/api/cron/followups", "schedule": "0 11 * * *"},
    {"path": "/api/cron/reports", "schedule": "0 8 * * 1"},
    {"path": "/api/cron/meta-token-refresh", "schedule": "0 9 * * 1"}
  ]
}
