# MarketingOS — Production Environment Variables
# Copy to Vercel dashboard → Settings → Environment Variables
# Generate secrets with: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────
# REQUIRED — App will not start without these
# ─────────────────────────────────────────────────────────────

# PostgreSQL (Neon)
DATABASE_URL=postgresql://neondb_owner:XXX@ep-XXX.neon.tech/neondb?sslmode=require

# JWT signing secrets — generate separately, never reuse
JWT_SECRET=<run: openssl rand -hex 32>
JWT_REFRESH_SECRET=<run: openssl rand -hex 32>

# AES-256-GCM for encrypting tokens in DB
ENCRYPTION_KEY=<run: openssl rand -hex 32>

# Internal API secrets (cron jobs, webhooks)
INTERNAL_API_KEY=<run: openssl rand -hex 32>
WEBHOOK_SECRET=<run: openssl rand -hex 32>
CRON_SECRET=<run: openssl rand -hex 32>

# Production domain
NEXT_PUBLIC_APP_URL=https://marketingos.co.il
NEXT_PUBLIC_BASE_URL=https://marketingos.co.il
NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# AI — console.anthropic.com
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────────────────────
# IMAGE UPLOADS — cloudinary.com
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=dvlkxxelo
CLOUDINARY_API_KEY=727546237966938
CLOUDINARY_API_SECRET=<your-api-secret>
CLOUDINARY_UPLOAD_PRESET=marketingos
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dvlkxxelo
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=marketingos

# ─────────────────────────────────────────────────────────────
# EMAIL — resend.com
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=MarketingOS <noreply@marketingos.co.il>
FROM_EMAIL=noreply@marketingos.co.il

# ─────────────────────────────────────────────────────────────
# WHATSAPP — green-api.com
# ─────────────────────────────────────────────────────────────
GREEN_API_INSTANCE_ID=7107574153
GREEN_API_TOKEN=<your-token>
GREEN_API_URL=https://7107.api.greenapi.com

# ─────────────────────────────────────────────────────────────
