# MarketingOS — Environment Variables

# Database (Neon)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
ADMIN_SECRET=

# AI
ANTHROPIC_API_KEY=

# Email
RESEND_API_KEY=
RESEND_FROM=MarketingOS <noreply@marketingos.co.il>

# WhatsApp (Green API)
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# Facebook / Meta
META_APP_ID=
META_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=

# Cloudinary
CLOUDINARY_URL=

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://marketingos.co.il
NEXT_PUBLIC_ROOT_DOMAIN=marketingos.co.il

# Cron
CRON_SECRET=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# n8n Railway
N8N_WEBHOOK_BASE_URL=https://your-n8n.up.railway.app
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vercel KV (Redis)
KV_REST_API_URL=
KV_REST_API_TOKEN=
