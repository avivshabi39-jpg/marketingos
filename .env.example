# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/marketing_db"

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── AI (Anthropic Claude) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@yourdomain.com"
FROM_EMAIL="reports@yourdomain.com"

# ─── WhatsApp (Green API — app.green-api.com) ───────────────────────────────
# Per-client credentials stored in the DB. These are system-level fallbacks.
# GREEN_API_INSTANCE_ID="1101XXXXXXXX"
# GREEN_API_TOKEN="..."

# ─── Media (Cloudinary) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_UPLOAD_PRESET="your_upload_preset"

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# ─── Facebook Lead Ads Webhook ───────────────────────────────────────────────
FACEBOOK_WEBHOOK_VERIFY_TOKEN="your_random_verify_token"
# FACEBOOK_ACCESS_TOKEN — stored per-client in DB; env is a global fallback
# FACEBOOK_ACCESS_TOKEN="EAAxxxxx"

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
CRON_SECRET="your_random_cron_secret"
